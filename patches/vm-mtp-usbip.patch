--- /dev/null
+++ b/etc/upstart/kindish-mtp-usbip.conf
@@ -0,0 +1,37 @@
+description "Export the stock Kindle MTP gadget from the VM over USB/IP"
+
+stop on stopping mtp
+
+respawn
+respawn limit 5 60
+
+script
+    gadget=/sys/kernel/config/usb_gadget/mtpgadget
+    for count in $(seq 1 120); do
+        [ -e "$gadget/functions/ffs.mtp/ready" ] && \
+            [ "$(cat "$gadget/functions/ffs.mtp/ready")" = 1 ] && break
+        sleep 1
+    done
+    [ -e "$gadget/functions/ffs.mtp/ready" ] || exit 1
+    [ "$(cat "$gadget/functions/ffs.mtp/ready")" = 1 ] || exit 1
+
+    /usr/bin/mtp.sh udc enable
+    for count in $(seq 1 30); do
+        [ -e /sys/bus/usb/devices/1-1/idVendor ] && break
+        sleep 1
+    done
+    [ "$(cat /sys/bus/usb/devices/1-1/idVendor)" = 1949 ] || exit 1
+    [ "$(cat /sys/bus/usb/devices/1-1/idProduct)" = 9981 ] || exit 1
+
+    export LD_LIBRARY_PATH=/usr/local/lib/kindish-usbip
+    /usr/local/sbin/kindish-usbip bind --busid=1-1
+    exec /usr/local/sbin/kindish-usbipd --ipv4 --debug
+end script
+
+post-stop script
+    export LD_LIBRARY_PATH=/usr/local/lib/kindish-usbip
+    /usr/local/sbin/kindish-usbip unbind --busid=1-1 2>/dev/null || true
+    if [ -e /sys/kernel/config/usb_gadget/mtpgadget/UDC ]; then
+        /usr/bin/mtp.sh udc disable 2>/dev/null || true
+    fi
+end script
