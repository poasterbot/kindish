diff --git a/drivers/gpu/drm/drm_fb_helper.c b/drivers/gpu/drm/drm_fb_helper.c
--- a/drivers/gpu/drm/drm_fb_helper.c
+++ b/drivers/gpu/drm/drm_fb_helper.c
@@ -1008,8 +1008,11 @@ int drm_fb_helper_setcmap(struct fb_cmap *cmap, struct fb_info *info)
 {
 	struct drm_fb_helper *fb_helper = info->par;
 	struct drm_device *dev = fb_helper->dev;
 	int ret;
 
+	if (!strcmp(dev->driver->name, "virtio_gpu"))
+		return 0;
+
 	if (oops_in_progress)
 		return -EBUSY;
 
@@ -1089,18 +1089,30 @@ int drm_fb_helper_ioctl(struct fb_info *info, unsigned int cmd,
 		ret = drm_crtc_vblank_get(crtc);
 		if (!ret) {
 			drm_crtc_wait_one_vblank(crtc);
 			drm_crtc_vblank_put(crtc);
 		}
 
 		ret = 0;
 		break;
 	default:
-		ret = -ENOTTY;
+		/*
+		 * Kindle's display supervisor configures the physical e-ink
+		 * controller with private ioctls in the 'F' namespace before it
+		 * launches Xorg. A virtio GPU has no waveform/update-scheme
+		 * hardware; its fbdev damage path presents writes automatically.
+		 * Accept those controls as successful no-ops only on this virtual
+		 * adapter so the stock supervisor can manage the real X stack.
+		 */
+		if (!strcmp(dev->driver->name, "virtio_gpu") &&
+		    _IOC_TYPE(cmd) == 'F')
+			ret = 0;
+		else
+			ret = -ENOTTY;
 	}
 
 	drm_master_internal_release(dev);
 unlock:
 	mutex_unlock(&fb_helper->lock);
 	return ret;
 }
 EXPORT_SYMBOL(drm_fb_helper_ioctl);
