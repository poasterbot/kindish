#!/usr/bin/env bash
set -euo pipefail
root="$(cd "$(dirname "$0")" && pwd)"

usage() {
  cat <<'EOF'
Usage: ./kindish COMMAND

  setup       Provision Ubuntu host dependencies through mise
  fetch       Download and verify the official 5.19.2 KT6 recovery OTA
  extract     Extract the actual Amazon root filesystem and boot images
  inspect     Show OTA, FIT kernel, and filesystem metadata
  start       Launch the offline interactive Kindle UI and local noVNC
  stop        Stop the UI, MTP gadget, and runtime mounts
  status      Show runtime status and browser address
  mtp-start   Attach the Kindle's tizen-mtp as a local virtual USB device
  mtp-stop    Detach virtual USB MTP
EOF
}

command="${1:-}"
case "$command" in
  setup) exec "$root/scripts/setup-host.sh" ;;
  fetch) exec "$root/scripts/fetch-firmware.sh" ;;
  extract) exec "$root/scripts/extract-firmware.sh" ;;
  inspect) exec "$root/scripts/inspect-firmware.sh" ;;
  start) exec "$root/scripts/start.sh" ;;
  stop) exec "$root/scripts/stop.sh" ;;
  status) exec "$root/scripts/status.sh" ;;
  mtp-start) exec "$root/scripts/mtp-start.sh" ;;
  mtp-stop) exec "$root/scripts/mtp-stop.sh" ;;
  help|-h|--help|'') usage ;;
  *) printf 'Unknown command: %s\n\n' "$command" >&2; usage >&2; exit 2 ;;
esac
